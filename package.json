{
  "name": "meca-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "precommit": "npm run lint && npm run test",
    "clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache','.turbo'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\"",
    "rebuild": "npm run clean && npm run build",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "dev": "next dev -p 3001",
    "dev:clean": "npm run clean && next dev -p 3001",
    "dev:turbo": "next dev --turbo -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:e2e": "cross-env NEXT_PUBLIC_DISABLE_AUTH=1 DISABLE_AUTH=1 E2E_INSTANT_DIAGNOSTIC=1 next dev -p 3001",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "verify": "npm run lint && npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@types/nodemailer": "^8.0.0",
    "@upstash/redis": "^1.37.0",
    "chart.js": "^4.4.0",
    "framer-motion": "^11.18.2",
    "jspdf": "^2.5.2",
    "lucide-react": "^1.8.0",
    "next": "^15.1.0",
    "nodemailer": "^8.0.5",
    "puppeteer": "^24.41.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.0",
    "sanitize-html": "^2.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.11.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

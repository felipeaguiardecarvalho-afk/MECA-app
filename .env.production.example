# Production template — set these in Vercel Environment Variables (or merge into .env.production for self-hosted `next start`).
# Do not commit real keys.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Strongly recommended for correct canonical URLs and Open Graph:
NEXT_PUBLIC_SITE_URL=https://meca.app
